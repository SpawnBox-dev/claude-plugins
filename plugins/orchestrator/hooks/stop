#!/usr/bin/env bash
set -euo pipefail

# Fires before the main session exits.
# Blocks once to prompt knowledge capture. Session context vanishes
# on exit - any discoveries not captured are lost permanently.

INPUT=$(cat)

SID=$(echo "$INPUT" | grep -o '"session_id":"[^"]*"' | head -1 | cut -d'"' -f4)
SID="${SID:-unknown}"

MARKER="${TMPDIR:-/tmp}/orchestrator-stop-${SID}"

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

if [ ! -f "$MARKER" ]; then
  touch "$MARKER"
  REASON="Before ending this session, complete orchestrator housekeeping:\n\n1. Call \`save_progress\` with a summary of work done, open questions, and next steps.\n\n2. Scan your work for knowledge that would be lost. Call \`note\` for anything that matches:\n\n- A decision you made or recommended (type=decision) - what you chose, what you rejected, why\n- A pattern or convention you followed or established (type=convention)\n- A gotcha, footgun, or thing that broke unexpectedly (type=anti_pattern)\n- An architectural insight about how systems connect (type=architecture)\n- A risk or limitation you discovered (type=risk)\n- Something that was harder than expected or took multiple attempts (type=insight) - what made it hard, what finally worked\n- User behavior or preferences you observed (type=user_pattern, scope=global) - communication style, priorities, how they think\n- Work you completed (call update_work_item status=done if a tracked item)\n\n3. If any open threads were resolved, call \`close_thread\` on them.\n\nIf nothing applies for step 2, skip it. But most sessions produce at least one decision, gotcha, or user insight worth preserving.\n\nDo this quickly, then you can stop."
  ESCAPED=$(escape_for_json "$REASON")
  printf '{"decision":"block","reason":"%s"}' "$ESCAPED"
else
  exit 0
fi
