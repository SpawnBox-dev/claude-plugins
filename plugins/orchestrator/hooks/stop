#!/usr/bin/env bash
set -euo pipefail

# Read hook input from stdin
INPUT=$(cat)

# Extract session_id without jq - use bash parameter expansion
# Input is JSON like {"session_id":"abc123",...}
SID=$(echo "$INPUT" | grep -o '"session_id":"[^"]*"' | head -1 | cut -d'"' -f4)
SID="${SID:-unknown}"

# Marker file to track if we've already blocked once this session
MARKER="${TMPDIR:-/tmp}/orchestrator-stop-${SID}"

if [ ! -f "$MARKER" ]; then
  touch "$MARKER"
  printf '{"decision":"block","reason":"Before ending this session, complete orchestrator housekeeping:\n1. Call save_progress with a summary of work done, open questions, and next steps.\n2. Call note for any decisions, conventions, or anti-patterns discovered this session.\n3. If any open threads were resolved, call close_thread on them.\nDo this quickly, then you can stop."}'
else
  exit 0
fi
