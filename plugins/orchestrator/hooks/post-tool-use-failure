#!/usr/bin/env bash
set -euo pipefail

# Fires after any tool call that fails (new in Claude Code 2026).
#
# Automatic struggle detection: counts consecutive tool failures and
# escalates the injected guidance on repeat hits. The counter is
# reset by post-tool-use on any successful tool call, so a single
# stray failure never triggers the nudge.
#
# This replaces the static "if you're stuck, ask for help" language
# in the every-turn skill, which depends on the model noticing it is
# stuck. The hook fires from outside the model's attention loop, so
# the guidance lands even when the model has convinced itself that
# "one more retry" will fix things.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$SCRIPT_DIR/_lib.sh"

INPUT=$(cat 2>/dev/null || printf '')
SID=$(get_session_id "$INPUT")
STATE_DIR=$(get_state_dir)

STRUGGLE_FILE="$STATE_DIR/struggle-$SID"
COUNT=$(cat "$STRUGGLE_FILE" 2>/dev/null || printf '0')
COUNT=$((COUNT + 1))
printf '%s' "$COUNT" > "$STRUGGLE_FILE"

if [ "$COUNT" -lt 2 ]; then
    exit 0
fi

if [ "$COUNT" -ge 3 ]; then
    MSG="[orch] STOP. You have hit ${COUNT} consecutive tool failures. You are stuck. Invoke orchestrator:consult-concierge NOW with: (1) what you are trying to accomplish, (2) what you have tried, (3) what errors you are seeing. Do not retry until you have consulted the knowledge base - previous sessions may have solved this exact problem."
else
    MSG="[orch] Two tool calls failed in a row. Before trying a third approach, consider invoking orchestrator:consult-concierge. The knowledge base may have a documented gotcha for this exact situation. Retrying without context is how rework happens."
fi

ESCAPED=$(escape_for_json "$MSG")

cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "PostToolUseFailure",
    "additionalContext": "${ESCAPED}"
  }
}
EOF

exit 0
