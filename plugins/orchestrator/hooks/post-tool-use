#!/usr/bin/env bash
set -euo pipefail

# Fires after any tool call that succeeds. Scoped via matcher in
# hooks.json to only mcp__plugin_orchestrator_memory__* tools (so we
# do not pay even the small bash startup cost on every single tool).
#
# Two jobs:
#   1. Drop a per-turn marker so the PreToolUse gate knows the model
#      has already engaged with the orchestrator this turn. The marker
#      is cleared by UserPromptSubmit at the start of the next turn.
#   2. Append to the turn bridge file - a running record of which
#      orchestrator actions fired this turn. UserPromptSubmit reads
#      and injects this on the NEXT turn to give the model continuity
#      across turns that survives thinking compression.
#
# Also resets the struggle counter on any successful orchestrator
# call, since a successful lookup/note means the model is no longer
# stuck on the same error.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$SCRIPT_DIR/_lib.sh"

INPUT=$(cat 2>/dev/null || printf '')
SID=$(get_session_id "$INPUT")
TOOL=$(get_field "$INPUT" tool_name)
STATE_DIR=$(get_state_dir)

case "$TOOL" in
    mcp__plugin_orchestrator_memory__*)
        touch "$STATE_DIR/orch-active-$SID" 2>/dev/null || true

        ACTION="${TOOL#mcp__plugin_orchestrator_memory__}"
        BRIDGE_FILE="$STATE_DIR/bridge-$SID"
        if [ -f "$BRIDGE_FILE" ]; then
            EXISTING=$(cat "$BRIDGE_FILE" 2>/dev/null || printf '')
            printf '%s, %s' "$EXISTING" "$ACTION" > "$BRIDGE_FILE"
        else
            printf '%s' "$ACTION" > "$BRIDGE_FILE"
        fi
        ;;
esac

# Any successful tool call resets the consecutive-failure counter.
rm -f "$STATE_DIR/struggle-$SID" 2>/dev/null || true

exit 0
