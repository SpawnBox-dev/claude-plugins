#!/usr/bin/env bash
set -euo pipefail

EVENT_TYPE="${CLAUDE_HOOK_EVENT_NAME:-startup}"

case "$EVENT_TYPE" in
  compact) ORIENT_EVENT="compact" ;;
  clear)   ORIENT_EVENT="clear" ;;
  resume)  ORIENT_EVENT="resume" ;;
  *)       ORIENT_EVENT="startup" ;;
esac

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

CONTEXT="MANDATORY FIRST ACTIONS: (1) Call the orchestrator MCP \`briefing\` tool with event \"${ORIENT_EVENT}\". (2) Invoke the \`orchestrator:getting-started\` skill via the Skill tool. (3) From now on, invoke \`orchestrator:every-turn\` EVERY turn before and after acting. These are not optional."
ESCAPED=$(escape_for_json "$CONTEXT")

cat <<EOF
{
  "additional_context": "${ESCAPED}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${ESCAPED}"
  }
}
EOF

exit 0
