#!/usr/bin/env bash
set -euo pipefail

# SessionStart stays bash because the MCP server may not be connected yet
# at the moment this hook fires (cold-start race). Emits the boot directive
# and surfaces session_id to the agent. All other hook logic moved to the
# _hook_event MCP tool dispatcher in R6.

EVENT_TYPE="${CLAUDE_HOOK_EVENT_NAME:-startup}"
case "$EVENT_TYPE" in
  compact) ORIENT_EVENT="compact" ;;
  clear)   ORIENT_EVENT="clear" ;;
  resume)  ORIENT_EVENT="resume" ;;
  *)       ORIENT_EVENT="startup" ;;
esac

INPUT=""
if [ ! -t 0 ]; then INPUT=$(cat 2>/dev/null || printf ''); fi

SID=""
if [ -n "$INPUT" ]; then
  SID=$(printf '%s' "$INPUT" | grep -o '"session_id":"[^"]*"' | head -1 | cut -d'"' -f4 || printf '')
  case "$SID" in
    *[!a-zA-Z0-9_-]*|"") SID="" ;;
  esac
fi

# 0.30.56 (WI f0d66029 follow-up): durable name -> session_id map so the
# launchers' -Resume <name> resolves LAUNCH-TIME names (--name flag), not
# only in-app /rename'd ones. The SessionStart payload carries the live
# session title in `session_title`; CC records launch names NOWHERE durable
# (live sessions/<pid>.json dies with the process; the transcript only gets
# "Session renamed to:" lines from /rename). APPEND-ONLY tsv - concurrent
# booting sessions just append (no read-modify-write race); resumes
# (source:"resume") re-stamp their current name+id so the map stays fresh;
# resolver semantics are latest-entry-wins with loud multi-id disambiguation.
# Best-effort like every write in this hook: failure never breaks a boot.
# Names containing tabs, quotes or backslashes are SKIPPED rather than
# written mangled (launcher-given names never contain them).
NAME_TITLE=""
if [ -n "$INPUT" ]; then
  NAME_TITLE=$(printf '%s' "$INPUT" | grep -o '"session_title":"[^"\\]*"' | head -1 | cut -d'"' -f4 || printf '')
fi
if [ -n "$SID" ] && [ -n "$NAME_TITLE" ] && [ -n "${CLAUDE_PROJECT_DIR:-}" ]; then
  case "$NAME_TITLE" in
    *"$(printf '\t')"*|*'"'*|*'\'*) : ;; # unsafe chars - skip, keep map clean
    *)
      NAME_DIR="$CLAUDE_PROJECT_DIR/.orchestrator-state"
      mkdir -p "$NAME_DIR" 2>/dev/null || true
      printf '%s\t%s\t%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || printf '0')" "$SID" "$NAME_TITLE" \
        >> "$NAME_DIR/session-names.tsv" 2>/dev/null || true
      ;;
  esac
fi

# Persist to fallback file - the MCP server reads this when an agent forgets
# to pass session_id. Path matches getFallbackSessionId in mcp/server.ts.
#
# 0.30.19+: write to BOTH a per-PPID file AND the legacy single-file
# location. The per-PPID file is the race-free path: this hook's parent
# is claude.exe (the session-owning process), and the MCP child also
# parents to that claude.exe - so both processes agree on the PID and
# read/write the same file without contention from sibling claude
# sessions. The legacy file is kept for backwards compat with old MCPs.
#
# Why race-free: each claude session has a unique PID. Per-PPID file
# names (active-session-<pid>) are per-session, so concurrent siblings
# don't collide. The single-file legacy path was racy because all
# sessions wrote to the same name and last-writer-wins.
if [ -n "$SID" ] && [ -n "${CLAUDE_PROJECT_DIR:-}" ]; then
  STATE_DIR="$CLAUDE_PROJECT_DIR/.orchestrator-state"
  mkdir -p "$STATE_DIR" 2>/dev/null || true

  # Find the real claude.exe PID by walking up our process tree.
  #
  # 0.30.25 fix: bash $PPID is unreliable on Git Bash for Windows -
  # the MSYS layer assigns virtual PIDs that don't correspond to
  # real Windows process IDs. Previously the per-PID file ended up
  # as `active-session-1` which never matched what the bun was
  # looking for. Solution: on Windows, read /proc/$$/winpid (MSYS
  # provides the real Windows PID there) and walk from that PID via
  # PowerShell, mirroring the bun's findClaudeAncestorPid() walk.
  CLAUDE_PID=""
  case "$(uname -s 2>/dev/null || echo Windows)" in
    MINGW*|MSYS*|CYGWIN*|*NT*)
      # Windows (Git Bash / MSYS): start from /proc/$$/winpid (real
      # Windows PID for this bash, not the virtual MSYS PID). Walk
      # via PowerShell - Get-CimInstance is reliable across all
      # supported Win10/Win11 builds; wmic is being removed.
      WIN_PID=""
      if [ -r "/proc/$$/winpid" ]; then
        WIN_PID=$(cat "/proc/$$/winpid" 2>/dev/null | tr -d '[:space:]')
      fi
      if [ -n "$WIN_PID" ]; then
        CLAUDE_PID=$(powershell.exe -NoProfile -Command "
          \$walk = $WIN_PID
          for (\$i = 0; \$i -lt 10; \$i++) {
            try {
              \$p = Get-CimInstance Win32_Process -Filter \"ProcessId = \$walk\" -ErrorAction Stop
              if (-not \$p) { break }
              if (\$p.Name -eq 'claude.exe') { Write-Output \$walk; exit 0 }
              if (-not \$p.ParentProcessId -or \$p.ParentProcessId -eq 0 -or \$p.ParentProcessId -eq \$walk) { break }
              \$walk = \$p.ParentProcessId
            } catch { break }
          }
        " 2>/dev/null | tr -d '[:space:]' || printf '')
      fi
      ;;
    *)
      # Linux/Mac: walk via /proc/<pid>/stat (field 2 = comm in parens,
      # field after rparen is ppid).
      WALK_PID=$$
      for i in 1 2 3 4 5 6 7 8; do
        [ -r "/proc/$WALK_PID/stat" ] || break
        STAT=$(cat "/proc/$WALK_PID/stat" 2>/dev/null) || break
        NAME_LC=$(printf '%s' "$STAT" | sed 's/^[^(]*(//' | sed 's/).*$//' | tr '[:upper:]' '[:lower:]')
        REST=$(printf '%s' "$STAT" | sed 's/^.*) //')
        PPID_X=$(printf '%s' "$REST" | awk '{print $2}')
        if [ "$NAME_LC" = "claude" ] || [ "$NAME_LC" = "claude.exe" ]; then
          CLAUDE_PID=$WALK_PID; break
        fi
        if [ -z "$PPID_X" ] || [ "$PPID_X" = "0" ] || [ "$PPID_X" = "$WALK_PID" ]; then break; fi
        WALK_PID=$PPID_X
      done
      ;;
  esac

  # Per-claude.exe-PID file (race-free). Write whichever PID we
  # resolved; if the walk failed, write `active-session-$PPID` as
  # before (best-effort - the bun will fall through to legacy).
  if [ -n "$CLAUDE_PID" ]; then
    printf '%s' "$SID" > "$STATE_DIR/active-session-$CLAUDE_PID" 2>/dev/null || true
  elif [ -n "${PPID:-}" ]; then
    printf '%s' "$SID" > "$STATE_DIR/active-session-$PPID" 2>/dev/null || true
  fi
  # Legacy single-file (preserved for pre-0.30.19 MCPs and as a
  # fallback when per-PID resolution fails).
  printf '%s' "$SID" > "$STATE_DIR/active-session" 2>/dev/null || true
  if [ ! -f "$STATE_DIR/.gitignore" ]; then
    printf '*\n' > "$STATE_DIR/.gitignore" 2>/dev/null || true
  fi
fi

SID_LINE=""
if [ -n "$SID" ]; then
  SID_LINE="\\n\\nYour session ID for this conversation is: ${SID}\\nPass this as \\\`session_id\\\` on EVERY orchestrator tool call. It enables cross-session discovery so sibling sessions see what you create and you see what they're working on."
fi

CONTEXT="MANDATORY FIRST ACTIONS: (1) Call \\\`briefing\\\` with event \\\"${ORIENT_EVENT}\\\" AND session_id set. (2) Invoke \\\`orchestrator:getting-started\\\`. (3) From now on, invoke \\\`orchestrator:every-turn\\\` EVERY turn before and after acting. These are not optional.${SID_LINE}"

# Bash JSON escape: backslash, quote, newline, tab, control chars.
ESC="$CONTEXT"
ESC="${ESC//\\/\\\\}"
ESC="${ESC//\"/\\\"}"
ESC="${ESC//$'\n'/\\n}"
ESC="${ESC//$'\r'/\\r}"
ESC="${ESC//$'\t'/\\t}"

cat <<EOF
{
  "additional_context": "${ESC}",
  "hookSpecificOutput": { "hookEventName": "SessionStart", "additionalContext": "${ESC}" }
}
EOF

exit 0
