#!/usr/bin/env bash
set -euo pipefail

# Fires before a write-class tool (Write/Edit/MultiEdit/NotebookEdit).
#
# Option B escalation (v0.20+):
#   - Turn 1: free pass (fresh session, let briefing/getting-started run)
#   - Turn 2-3 with zero orch activity this turn: soft additionalContext nudge
#   - Turn 4+ with zero orch activity this turn: permissionDecision:"ask"
#     -> Claude Code shows an interactive approval prompt. User can approve
#        to proceed, or deny and let the model pivot to an orchestrator call.
#
# The escalation only fires when this turn has had NO orchestrator MCP tool
# call. Sessions that briefing/lookup/check_similar on every turn never see
# the nag at all. Once fired per turn (preuse-warned marker), won't fire
# again until UserPromptSubmit resets the turn state.
#
# The nag is scoped per-turn, not per-session: a session that called orch
# on turn 1 but not turn 2 IS nagged on turn 2. The turn counter is
# session-global so "turn 4+" means "the session is past its third turn"
# regardless of how many of those turns were orch-clean.
#
# Subagent marker race (MEDIUM fix): parallel Task subagents share the
# parent's session_id, so the marker suffix is session_id + agent_id
# (when present) to prevent spurious duplicate warnings when multiple
# subagents invoke a write tool near-simultaneously.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$SCRIPT_DIR/_lib.sh"

INPUT=$(cat 2>/dev/null || printf '')
SID=$(get_session_id "$INPUT")
AID=$(get_agent_id "$INPUT")
STATE_DIR=$(get_state_dir)

# Scope per-turn markers by session_id + optional agent_id so sibling
# subagents don't clobber each other.
SUFFIX="$SID"
if [ -n "$AID" ] && [ "$AID" != "unknown" ]; then
    SUFFIX="${SID}-${AID}"
fi

TURN_FILE="$STATE_DIR/turn-$SID"
# Defence against `set -u` breaking on an empty or whitespace-only turn file.
TURN_RAW=$(cat "$TURN_FILE" 2>/dev/null || printf '0')
TURN="${TURN_RAW:-0}"
# Strip anything non-numeric just in case (paranoia layer for the `-lt` compare).
case "$TURN" in
    *[!0-9]*|"") TURN="0" ;;
esac

# Turn 1: free pass. Fresh sessions shouldn't be nagged before they have
# a chance to run briefing or lookup as part of getting-started.
if [ "$TURN" -lt 2 ]; then
    exit 0
fi

ORCH_ACTIVITY_FILE="$STATE_DIR/orch-active-$SID"
if [ -f "$ORCH_ACTIVITY_FILE" ]; then
    # Model already used an orchestrator tool this turn - no nag needed.
    exit 0
fi

WARNED_FILE="$STATE_DIR/preuse-warned-$SUFFIX"
if [ -f "$WARNED_FILE" ]; then
    # Already fired once this turn for this (session, agent) pair.
    exit 0
fi
touch "$WARNED_FILE" 2>/dev/null || true

# Escalation threshold: soft nudge on turns 2-3, ask on turn 4+.
if [ "$TURN" -ge 4 ]; then
    REASON="Orchestrator discipline check: you are past turn ${TURN} of this session and have not called any orchestrator tool this turn. Prior turns' nudges have been soft. This is the escalation: approve to proceed with this write (explicit choice to skip orch for this turn), or deny and first call orchestrator:consult-concierge, lookup, or briefing to check for relevant decisions, conventions, or anti-patterns. If you are deliberately working in an area without orch coverage, approving is the right call - this prompt exists to make that a conscious decision, not a default."
    ESCAPED=$(escape_for_json "$REASON")
    cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "PreToolUse",
    "permissionDecision": "ask",
    "permissionDecisionReason": "${ESCAPED}"
  }
}
EOF
    exit 0
fi

# Turns 2-3: soft additionalContext injection. Non-blocking, zero surprise.
MSG="[orch] Turn ${TURN}: you are about to modify code but have not called any orchestrator tool this turn. Consider whether a prior decision, convention, or anti-pattern applies here. A 2-second lookup can save 20 minutes of rework. This reminder fires once per turn; from turn 4 onward this becomes an interactive approval prompt (Option B escalation)."
ESCAPED=$(escape_for_json "$MSG")

cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "PreToolUse",
    "permissionDecision": "allow",
    "additionalContext": "${ESCAPED}"
  }
}
EOF

exit 0
