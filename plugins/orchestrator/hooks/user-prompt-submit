#!/usr/bin/env bash
set -euo pipefail

# Fires before Claude processes every user message.
# Injects a lightweight every-turn prompt into context.
# This is the "pre-turn" enforcement hook - the model sees this
# reminder right before it thinks, every single turn.

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

CONTEXT="[orch] REFLECT on last turn: did you note decisions, capture patterns, update work items, or close threads? If you used 0 orchestrator tools, ask yourself why - most turns have signal. THEN for this turn: lookup needed? Decisions to check? Scan the every-turn action table."
ESCAPED=$(escape_for_json "$CONTEXT")

cat <<EOF
{
  "additional_context": "${ESCAPED}",
  "hookSpecificOutput": {
    "hookEventName": "UserPromptSubmit",
    "additionalContext": "${ESCAPED}"
  }
}
EOF

exit 0
