#!/usr/bin/env bash
set -euo pipefail

# Fires before a subagent exits. Blocks once per session to prompt
# knowledge capture AND maintenance - subagents work in isolation and
# their context vanishes on exit, so any discoveries not captured via
# note/update_note/close_thread/supersede_note are lost permanently.
#
# R3.4: Maintenance verbs are equal-priority to capture.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$SCRIPT_DIR/_lib.sh"

INPUT=$(cat)
SID=$(get_session_id "$INPUT")
STATE_DIR=$(get_state_dir)

MARKER="$STATE_DIR/subagent-stop-$SID"

if [ ! -f "$MARKER" ]; then
  touch "$MARKER" 2>/dev/null || true
  REASON="Before exiting, complete orchestrator housekeeping. Maintenance is equal-priority to capture:\n\n**1. Curate what you used (update_note / close_thread / supersede_note).** For every lookup result you relied on:\n- Was it still correct? If not, call \`update_note\` (minor correction) or \`supersede_note\` (replacement).\n- Is a tracked thread now settled by your work? Call \`close_thread\`.\n- Stale notes actively mislead future sessions - fix them now.\n\n**2. Capture new knowledge (note).** Scan your work for anything that would be lost:\n- A decision you made or recommended (type=decision) - what you chose, what you rejected, why\n- A pattern or convention (type=convention) or anti-pattern / gotcha (type=anti_pattern)\n- An architectural insight (type=architecture), risk (type=risk), or hard-won insight (type=insight)\n- User behavior or preferences (type=user_pattern, scope=global)\n- Work completed on a tracked item (call \`update_work_item\` status=done)\n\n**3. Optional: \`retro\`.** If you discovered many gotchas during this work, run retro to decay stale signals and consolidate before exiting.\n\nIf nothing applies, exit. But most work produces at least one decision, gotcha, or insight worth preserving - AND at least one existing note worth updating/closing."
  ESCAPED=$(escape_for_json "$REASON")
  printf '{"decision":"block","reason":"%s"}' "$ESCAPED"
else
  exit 0
fi
